{
  "expo": {
    "name": "Stock Sync",
    "slug": "stock-sync-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/logo-fondo.png",
    "splash": {
      "image": "./assets/logo-fondo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stocksync.mobile"
    },
    "android": {
      "package": "com.stocksync.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-fondo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [],
    "owner": "stock-sync",
    "extra": {
      "eas": {
        "projectId": "41910597-3f3f-48c2-801e-8eaf2cf0b2b1"
      }
    }
  }
}
